{
  "compilerOptions": {
    "target": "ES2022",                          // Modern JavaScript features
    "module": "NodeNext",                        // Modern Node.js module resolution
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],                           // Add "DOM" here if you are building for the browser
    "outDir": "./dist",                          // Where compiled JS goes
    "rootDir": "./src",
    
    /* Add for tests */
    "isolatedModules": true,       // Fixes the ts-jest hybrid module warning
    "types": ["jest", "node"],// Where your source code lives

    /* Strict Type-Checking */
    "strict": true,                              // Enables a broad suite of type-checking behaviors
    
    /* Granular Strict Flags (Enforced by strict: true, but good to know) */
    "noImplicitAny": true,                       // Error on expressions and declarations with an implied 'any' type
    "strictNullChecks": true,                    // Controls how null and undefined are handled
    "strictFunctionTypes": true,                 // Ensure function parameters are checked correctly
    "strictBindCallApply": true,                 // Check the arguments of bind, call, and apply methods
    "strictPropertyInitialization": true,        // Ensure class properties are initialized in the constructor
    "noImplicitThis": true,                      // Raise error on 'this' expressions with an implied 'any' type
    "useUnknownInCatchVariables": true,          // Default type for catch clause variables to 'unknown'

    /* Additional Linter-like Checks (Highly Recommended) */
    "noUnusedLocals": true,                      // Error on unused local variables
    "noUnusedParameters": true,                  // Error on unused function parameters
    "noImplicitReturns": true,                   // Ensure all code paths in a function return a value
    "noFallthroughCasesInSwitch": true,          // Report errors for fallthrough cases in switch statements
    "noUncheckedIndexedAccess": true,            // Objects/Arrays accessed via index signatures return 'undefined'

    /* Interop Constraints */
    "esModuleInterop": true,                     // Emits additional JavaScript to ease support for importing CommonJS modules
    "forceConsistentCasingInFileNames": true,    // Ensure casing is correct in imports
    
    /* Advanced */
    "skipLibCheck": true                         // Skip type checking of declaration files (.d.ts) to speed up compilation
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}